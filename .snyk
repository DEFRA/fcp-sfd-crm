# Snyk (https://snyk.io) policy file
version: v1.25.0
ignore:
  SNYK-JS-JOI-17317897:
    - hapi-pulse > joi:
        reason: >
          hapi-pulse pins joi@17.9.2 which has a medium-severity uncaught exception CVE.
          A fix has been merged upstream in hapi-pulse but not yet released.
          Risk is low for an internal service where untrusted input does not reach
          hapi-pulse's Joi validation. Tech debt ticket raised to replace hapi-pulse
          once a fixed version is published.
        expires: '2026-12-31T00:00:00.000Z'
