{
  "name": "fcp-sfd-crm",
  "version": "0.1.0",
  "description": "CRM orchestration service for SFD (Single Front Door)",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=11.10"
  },
  "scripts": {
    "docker:build": "docker compose build",
    "docker:dev": "docker compose up",
    "docker:dev:d": "docker compose up -d",
    "docker:stop": "docker compose down",
    "docker:stop:v": "docker compose down -v",
    "docker:debug": "docker compose -f compose.yaml -f compose.debug.yaml -p 'fcp-sfd-crm' up",
    "docker:test": "docker compose down -v && docker compose -f compose.yaml -f compose.test.yaml run  --build --rm 'fcp-sfd-crm'",
    "docker:test:watch": "docker compose down -v && docker compose -f compose.yaml -f compose.test.yaml -f compose.test.watch.yaml run  --build --rm 'fcp-sfd-crm'",
    "test": "rm -rf ./coverage/** && vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "npx eslint . --ext .js",
    "lint:fix": "npx eslint . --ext .js --fix",
    "start:watch": "nodemon --watch src --exec 'node --experimental-vm-modules --inspect=0.0.0.0:9232 src/index.js'",
    "start:debug": "nodemon --watch src --exec 'node --experimental-vm-modules --inspect-brk=0.0.0.0:9232 src/index.js'",
    "start": "node --experimental-vm-modules src/index.js",
    "sonar": "node scripts/local-sonar-scan.js"
  },
  "author": "Defra DDTS",
  "contributors": [
    "Rana Salem <rana.salem@defra.gov.uk>",
    "Fay Toward <fay.toward@defra.gov.uk>",
    "Simon Dunn <simon.dunn1@defra.gov.uk>"
  ],
  "dependencies": {
    "@aws-sdk/client-sns": "3.1060.0",
    "@aws-sdk/client-sqs": "3.1060.0",
    "@aws-sdk/credential-providers": "3.1060.0",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@fetchkit/ffetch": "5.5.4",
    "@hapi/boom": "10.0.1",
    "@hapi/hapi": "21.4.9",
    "aws-embedded-metrics": "4.2.1",
    "aws4": "1.13.2",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "global-agent": "4.1.3",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "3.0.1",
    "http-status-codes": "2.3.0",
    "https-proxy-agent": "9.0.0",
    "joi": "18.2.1",
    "mongo-locks": "3.1.2",
    "mongodb": "7.2.0",
    "node-fetch": "3.3.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "sqs-consumer": "15.0.2",
    "undici": "8.3.0"
  },
  "devDependencies": {
    "@fetchkit/chaos-fetch": "1.2.1",
    "@vitest/coverage-v8": "4.1.8",
    "autoprefixer": "10.5.0",
    "dotenv": "17.4.2",
    "eslint": "9.39.0",
    "neostandard": "0.13.0",
    "nodemon": "3.1.14",
    "npm-run-all": "4.1.5",
    "vitest": "4.1.8"
  },
  "overrides": {
    "fast-xml-parser": "5.7.1",
    "fast-xml-builder": "1.2.0",
    "@hapi/content": "6.0.2",
    "uuid": "14.0.0"
  }
}
