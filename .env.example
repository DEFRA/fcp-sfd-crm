NODE_ENV=local

# Service
SERVICE_VERSION=local
HOST=0.0.0.0
PORT=3009
ENVIRONMENT=local
LOG_ENABLED=true
LOG_LEVEL=info
LOG_FORMAT=pino-pretty

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DATABASE=fcp-sfd-crm

# HTTP proxy (optional)
# HTTP_PROXY=http://proxy.example.com:3128

# CRM auth
CRM_AUTH_ENDPOINT=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
CRM_AUTH_CLIENT_ID=<client-id>
CRM_AUTH_CLIENT_SECRET=<client-secret>
CRM_AUTH_SCOPE=<scope>

# CRM API
CRM_API_BASE_URL=https://<your-crm-host>/api

# Queue
CRM_QUEUE_URL=http://localhost:4566/000000000000/fcp_sfd_crm_requests
CRM_DEAD_LETTER_QUEUE_URL=http://localhost:4566/000000000000/fcp_sfd_crm_requests_deadletter
AWS_REGION=eu-west-2
QUEUE_POLL_INTERVAL_MS=5000
CRM_EVENTS_TOPIC_ARN=arn:aws:sns:eu-west-2:000000000000:fcp_sfd_crm_events
AUDIT_TOPIC_ARN=arn:aws:sns:eu-west-2:000000000000:fcp_audit_fcp_sfd_crm

# API key used for local/manual test case creation
API_KEY_FOR_TESTING_CASE_CREATION=change-me

AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SQS_ENDPOINT=http://floci:4566
AWS_SNS_ENDPOINT=http://floci:4566

# HTTP retry policy
HTTP_RETRY_MAX_ATTEMPTS=3
HTTP_RETRY_BASE_DELAY_MS=500
HTTP_RETRY_BACKOFF_MULTIPLIER=1.5
HTTP_RETRY_JITTER_PERCENTAGE=15
HTTP_RETRY_MAX_DELAY_MS=15000

# HTTP timeout policy
CRM_HTTP_TIMEOUT_MS=10000
CRM_AUTH_HTTP_TIMEOUT_MS=5000

# Unknown error retry policy
RETRY_UNKNOWN_MAX_ATTEMPTS=2
RETRY_UNKNOWN_MAX_DELAY_MS=10000
